{
  "name": "chat-runtime-context",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:accessibility": "vitest run test/core/react/accessibility",
    "whitepaper:dev": "vite --config whitepaper/vite.config.ts",
    "whitepaper:build": "tsc -p whitepaper/tsconfig.json --noEmit && vite build --config whitepaper/vite.config.ts && node whitepaper/scripts/finalize-build.mjs",
    "whitepaper:test": "vitest run test/whitepaper",
    "whitepaper:preview": "vite preview --config whitepaper/vite.config.ts"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57",
    "@xyflow/react": "12.11.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.1",
    "use-sync-external-store": "^1.6.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/use-sync-external-store": "^1.5.0",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-singlefile": "2.3.3",
    "vitest": "^4.1.10"
  }
}
